# ArcReel Generator Environment Configuration
# Copy this file to .env and fill in your values
#
# 大部分配置（API Key、后端选择、速率限制、模型选择等）
# 已迁移至 WebUI 配置页（/settings），首次启动后通过页面配置即可。
# 此文件仅保留启动级/基础设施配置。

# ============================================================
# 认证配置 (Authentication)
# ============================================================
# 登录用户名（默认: admin）
AUTH_USERNAME=admin
# 登录密码（留空则首次启动时自动生成并回写到此文件）
AUTH_PASSWORD=
# JWT 签名密钥（留空则自动生成，但重启后 token 失效需重新登录）
AUTH_TOKEN_SECRET=

# ============================================================
# 数据库配置 (Database Configuration)
# ============================================================
# 默认使用 SQLite（开发/单机）
# SQLite:     sqlite+aiosqlite:///./projects/.arcreel.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/arcreel
# DATABASE_URL=sqlite+aiosqlite:///./projects/.arcreel.db

# ============================================================
# 日志配置 (Logging)
# ============================================================
# 日志级别（默认: INFO，可选: DEBUG, WARNING, ERROR）
# LOG_LEVEL=INFO

# ============================================================
# 视频供应商 (Video Provider)
# ============================================================
# DEFAULT_VIDEO_PROVIDER=gemini     # 全局默认视频供应商 (gemini | seedance)

# ============================================================
# Seedance (火山方舟) 配置
# ============================================================
# ARK_API_KEY=                      # 火山方舟 API key
# FILE_SERVICE_BASE_URL=            # 项目文件服务公网地址 (Seedance 图片上传需要公网访问)
